{
  "name": "cardpin",
  "private": true,
  "version": "1.2.16",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "pnpm compile:data && turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format:data": "tsx scripts/format-datasets.ts",
    "validate:data": "tsx scripts/compile-datasets.ts --validate-only",
    "compile:data": "tsx scripts/compile-datasets.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "pnpm": "10.34.4",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "brace-expansion": "^2.1.2",
    "js-yaml": "^4.3.0",
    "sharp": "^0.35.0",
    "esbuild": "^0.28.1"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.12",
      "brace-expansion": "^2.1.2",
      "js-yaml": "^4.3.0",
      "sharp": "^0.35.0",
      "esbuild": "^0.28.1"
    }
  }
}
